<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>English</string>

    <key>CFBundleExecutable</key>
    <string>@MACOSX_BUNDLE_EXECUTABLE_NAME@</string>

    <key>CFBundleIdentifier</key>
    <string>@MACOSX_BUNDLE_GUI_IDENTIFIER@</string>

    <key>CFBundleName</key>
    <string>@MACOSX_BUNDLE_BUNDLE_NAME@</string>

    <key>CFBundleDisplayName</key>
    <string>Thoth</string>

    <key>CFBundlePackageType</key>
    <string>APPL</string>

    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>

    <key>CFBundleVersion</key>
    <string>@MACOSX_BUNDLE_BUNDLE_VERSION@</string>

    <key>CFBundleShortVersionString</key>
    <string>@MACOSX_BUNDLE_SHORT_VERSION_STRING@</string>

    <key>CFBundleGetInfoString</key>
    <string>Thoth – Language Shadowing Practice</string>

    <key>NSHumanReadableCopyright</key>
    <string>@MACOSX_BUNDLE_COPYRIGHT@</string>

    <!-- Minimum macOS version: Qt 6 requires 12.0+ -->
    <key>LSMinimumSystemVersion</key>
    <string>12.0</string>

    <!-- Microphone access for shadowing recording -->
    <key>NSMicrophoneUsageDescription</key>
    <string>Thoth uses the microphone to record your shadowing practice sessions.</string>

    <key>NSHighResolutionCapable</key>
    <true/>

    <key>NSSupportsAutomaticGraphicsSwitching</key>
    <true/>
</dict>
</plist>
