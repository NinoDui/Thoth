CompileFlags:
  CompilationDatabase: build

  Add:
    - -std=c++20
    - -Iinclude
    - -Isrc/core
    - -finput-charset=UTF-8
    - -fexec-charset=UTF-8

  Remove:
    - -W*
    - -w
    - /W*

Diagnostics:
  UnusedIncludes: None
  MissingIncludes: None
  ClangTidy:
    Remove:
      - llvmlibc-*
      - misc-non-private-member-variables-in-classes

Index:
  Background: Build
